// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// NextAuth.js Models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model User {
  id            String    @id @default(cuid())
  username      String?   @unique
  password      String?
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  dailyFocusGoal Int      @default(240) // daily focus goal in minutes

  accounts         Account[]
  sessions         Session[]
  tasks            Task[]
  projects         Project[]
  pomodoroSessions PomodoroSession[]
  presets          PomodoroPreset[]
  analytics        Analytics[]
  syncEvents       SyncEvent[]
  tags             Tag[]
  categories       Category[]
  attachments      Attachment[]
  calendarEvents   CalendarEvent[]
  deepWorkSessions DeepWorkSession[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Task Management
enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskDifficulty {
  EASY
  MEDIUM
  HARD
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  READY_FOR_REVIEW
  COMPLETED
  ON_HOLD
  ARCHIVED
}

enum RecurrenceType {
  DAILY
  WEEKLY
  MONTHLY
  CUSTOM
}

enum AttachmentType {
  FILE
  LINK
}

model Task {
  id                   String       @id @default(cuid())
  title                String
  description          String?      @db.Text
  notes                String?      @db.Text
  status               TaskStatus   @default(TODO)
  priority             TaskPriority @default(MEDIUM)
  estimatedPomodoros   Int          @default(1)
  completedPomodoros   Int          @default(0)
  pomodoroDuration     Int          @default(25) // duration in minutes
  project              String?
  projectId            String?
  columnId             String?
  columnOrder          Int          @default(0)
  categoryId           String?
  difficulty           TaskDifficulty?
  dueDate              DateTime?
  completedAt          DateTime?
  autoComplete         Boolean      @default(false)
  
  // Recurrence
  isRecurring          Boolean         @default(false)
  recurrenceType       RecurrenceType?
  recurrenceInterval   Int?            @default(1)
  recurrenceDays       String?         // e.g., "1,3,5" for Mon,Wed,Fri
  lastOccurrenceId     String?         // ID of the next task generated from this one
  
  sortOrder            Int          @default(0)
  userId               String
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectRef       Project?          @relation(fields: [projectId], references: [id], onDelete: SetNull)
  column           Column?           @relation(fields: [columnId], references: [id], onDelete: SetNull)
  category         Category?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  pomodoroSessions PomodoroSession[]
  subtasks         SubTask[]
  tags             Tag[]
  attachments      Attachment[]
  calendarEvents   CalendarEvent[]
  deepWorkSessions DeepWorkSession[]

  @@index([userId, createdAt])
  @@index([userId, status])
  @@index([userId, project])
  @@index([projectId])
  @@index([columnId, columnOrder])
}

// Projects
model Project {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  color       String   @default("#3B82F6")
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  columns          Column[]
  tasks            Task[]
  deepWorkSessions DeepWorkSession[]

  @@index([userId])
}

model Column {
  id        String   @id @default(cuid())
  name      String
  sortOrder Int      @default(0)
  projectId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@index([projectId, sortOrder])
}

// Organization & Classification
model Tag {
  id        String   @id @default(cuid())
  name      String
  color     String?
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@unique([userId, name])
  @@index([userId])
}

model Category {
  id        String   @id @default(cuid())
  name      String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@unique([userId, name])
  @@index([userId])
}

// Subtasks
model SubTask {
  id          String   @id @default(cuid())
  title       String
  notes       String?  @db.Text
  isCompleted Boolean  @default(false)
  sortOrder   Int      @default(0)
  taskId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, sortOrder])
}

model Attachment {
  id        String         @id @default(cuid())
  name      String
  url       String         @db.Text
  size      Int?           // Size in bytes (for files)
  mimeType  String?
  type      AttachmentType
  taskId    String
  userId    String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([userId])
}

// Pomodoro Timer
enum SessionType {
  FOCUS
  SHORT_BREAK
  LONG_BREAK
}

model PomodoroSession {
  id             String      @id @default(cuid())
  type           SessionType
  duration       Int         // in seconds
  completedAt    DateTime    @default(now())
  wasInterrupted Boolean     @default(false)
  interruptions  Int         @default(0)
  rating         Int?        // 1-5 focus quality rating
  taskId         String?
  userId         String
  createdAt      DateTime    @default(now())
  
  deepWorkSessionId String?
  deepWorkSession   DeepWorkSession? @relation(fields: [deepWorkSessionId], references: [id], onDelete: SetNull)

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task? @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([userId, completedAt])
  @@index([taskId])
  @@index([deepWorkSessionId])
}

model DeepWorkSession {
  id             String      @id @default(cuid())
  workspaceId    String?     // For future multi-workspace support
  startTime      DateTime    @default(now())
  endTime        DateTime?
  totalDuration  Int         @default(0) // total time in seconds across all cycles
  sessionCount   Int         @default(0) // number of focus cycles
  interruptions  Int         @default(0)
  taskId         String?
  projectId      String?
  distractions   Json?       // Array of strings or objects with timestamps
  energy         Int?        // focus quality or energy level (1-5)
  userId         String
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  task             Task?             @relation(fields: [taskId], references: [id], onDelete: SetNull)
  projectRef       Project?          @relation(fields: [projectId], references: [id], onDelete: SetNull)
  pomodoroSessions PomodoroSession[]

  @@index([userId, startTime])
  @@index([taskId])
  @@index([projectId])
}

model PomodoroPreset {
  id                String   @id @default(cuid())
  name              String
  focusDuration     Int      // in minutes
  shortBreakDuration Int     // in minutes
  longBreakDuration Int      // in minutes
  sessionsUntilLongBreak Int @default(4)
  autoStartBreaks   Boolean  @default(true)
  autoStartFocus    Boolean  @default(false)
  isDefault         Boolean  @default(false)
  userId            String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Analytics
model Analytics {
  id                 String   @id @default(cuid())
  date               DateTime @db.Date
  totalPomodoros     Int      @default(0)
  totalFocusTime     Int      @default(0) // in seconds
  tasksCompleted     Int      @default(0)
  interruptions      Int      @default(0)
  focusScore         Float    @default(0)
  userId             String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

// Offline Sync
enum SyncEventType {
  TASK_CREATE
  TASK_UPDATE
  TASK_DELETE
  SESSION_COMPLETE
  PRESET_CREATE
  PRESET_UPDATE
  PRESET_DELETE
}

enum SyncStatus {
  PENDING
  SYNCED
  FAILED
}

model SyncEvent {
  id        String        @id @default(cuid())
  type      SyncEventType
  payload   Json
  status    SyncStatus    @default(PENDING)
  retries   Int           @default(0)
  userId    String
  createdAt DateTime      @default(now())
  syncedAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([createdAt])
}

// Calendar Events
model CalendarEvent {
  id        String   @id @default(cuid())
  title     String
  start     DateTime
  end       DateTime
  allDay    Boolean  @default(false)
  color     String?  // Override color, defaults to project color
  notes     String?  @db.Text
  taskId    String?  // Optional link to a Task
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task? @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([userId, start])
  @@index([taskId])
}

// System Configuration for Self-Hosting
model SystemConfig {
  id                    String   @id @default("singleton")
  enableGoogleAuth      Boolean  @default(false)
  enableCredentialsAuth Boolean  @default(true)
  updatedAt             DateTime @updatedAt
}
